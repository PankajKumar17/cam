# ── COPY THIS FILE TO .env AND FILL IN YOUR KEYS ──────────
# cp .env.example .env

# LLM — Required for all AI-generated CAM, bull/bear analysis, research
GEMINI_API_KEY=AIza...

# Web Research — Required for company news & industry outlook (Layer 7)
TAVILY_API_KEY=tvly-...

# Satellite Imagery — Optional (falls back to synthetic score if absent)
# NOTE: code reads SENTINEL_CLIENT_ID (not SENTINEL_HUB_CLIENT_ID)
SENTINEL_CLIENT_ID=...
SENTINEL_CLIENT_SECRET=...

# App Config
DEMO_COMPANY=sunrise_textile_mills
LOG_LEVEL=INFO
